# ~/.zshrc — managed by ws_config
# Skills append their source lines below this line.

# Derive repo root from the symlink at ~/.zshrc
WS_CONFIG_DIR="$(cd "$(dirname "$(readlink -f "$HOME/.zshrc")")/../.." && pwd)"

source "$WS_CONFIG_DIR/dotfiles/wss-tmux/tmux_alias.sh"
source "$WS_CONFIG_DIR/dotfiles/wss-git-alias/git_alias.sh"

# oh-my-zsh + powerlevel10k (ws_config)
source "$WS_CONFIG_DIR/dotfiles/wss-ohmyzsh/zshrc_omz.sh"

# Override ll to hide extended attributes
alias ll='eza --icons --git-ignore --git -F -l'
