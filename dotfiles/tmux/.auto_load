#!/usr/bin/env bash
# tx_load: bootstrap standard tmux sessions (dev + tech).
# Usage: tx_load

DEV_SESSION="dev"
DEV_HOME="$HOME/gopath/src/gitlab.myteksi.net"

LOCAL_SESSION="ai"
LOCAL_HOME="$HOME/workspace/ai"

# --- dev session ---
tmux has-session -t "$DEV_SESSION" &>/dev/null
if [ $? != 0 ]; then
    tmux new-session -s "$DEV_SESSION" -n "arc"    -c "$DEV_HOME/gstf-engineering/grab-support-platform/arc"           -d
    tmux new-window  -n "nudges"  -c "$DEV_HOME/gophers/go/mex/nudges"                                               -t "$DEV_SESSION"
    tmux new-window  -n "ai-hub"  -c "$DEV_HOME/grab/entities/services/bpbg-ai-hub/bpbg-ai-hub"                      -t "$DEV_SESSION"
    tmux new-window  -n "others"  -c "$DEV_HOME"                                                                      -t "$DEV_SESSION"
fi

# --- ai session ---
tmux has-session -t "$LOCAL_SESSION" &>/dev/null
if [ $? != 0 ]; then
    tmux new-session  -s "$LOCAL_SESSION" -n "model" -c "$LOCAL_HOME" -d
    tmux new-window   -n "agent" -c "$LOCAL_HOME" -t "$LOCAL_SESSION"
    tmux new-window   -n "skill" -c "$LOCAL_HOME" -t "$LOCAL_SESSION"
    tmux select-window -t "$LOCAL_SESSION:agent"
fi

# attach to dev session
tmux select-window -t "$DEV_SESSION:arc"
tmux attach -t "$DEV_SESSION"
